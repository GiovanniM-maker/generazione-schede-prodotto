# ============================================================================
# Generatore AI Schede Prodotto Moda — variabili d'ambiente
# Copia questo file in `.env` (root) e in `apps/web/.env.local` / `apps/worker/.env`
# NON committare mai `.env` reali. Nessun segreto va hardcoded nel codice.
# ============================================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Publishable key (browser-safe, ex "anon key"). Solo questa nel browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service role key: SOLO server/worker. Mai nel browser, nei log, nel repo.
SUPABASE_SERVICE_ROLE_KEY=
# Connessione diretta al DB (worker / migrazioni / test SQL).
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- OpenAI ---
OPENAI_API_KEY=
# Nessun nome modello hardcoded nella business logic: sempre da env.
OPENAI_MODEL_BRAND_PROFILE=gpt-4o-mini
OPENAI_MODEL_COPY=gpt-4o-mini
OPENAI_MODEL_VISUAL=gpt-4o-mini
OPENAI_MODEL_AUDIT=gpt-4o-mini

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PACK_50=
STRIPE_PRICE_PACK_200=
STRIPE_PRICE_PACK_500=

# --- Worker ---
WORKER_CONCURRENCY=3
WORKER_POLL_INTERVAL_MS=2000
WORKER_VISIBILITY_TIMEOUT_SECONDS=300
MAX_JOB_ATTEMPTS=3

# --- Limiti upload / batch ---
MAX_CSV_SIZE_MB=10
MAX_XLSX_SIZE_MB=20
MAX_IMAGE_SIZE_MB=8
MAX_IMAGES_PER_BATCH=300
MAX_PRODUCTS_PER_BATCH=500

# --- Crediti ---
WELCOME_CREDITS=3
# Numero massimo di rigenerazioni gratuite del campione per batch.
MAX_SAMPLE_REGENERATIONS=5
# La rigenerazione manuale di un prodotto consuma credito? (true/false)
MANUAL_REGEN_CONSUMES_CREDIT=false

# --- Mock mode (SOLO development/test; l'app rifiuta di partire in prod se true) ---
ENABLE_MOCK_AI=true
ENABLE_MOCK_BILLING=true
